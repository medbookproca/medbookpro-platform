{
  "name": "medbookpro-platform",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22.13.0 <23.0.0",
    "pnpm": ">=11.0.0 <12.0.0"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:e2e": "playwright test",
    "docs:check": "node scripts/validate-launch-docs.mjs",
    "release:metadata": "node scripts/release-metadata.mjs",
    "release:check": "node scripts/release-metadata.mjs --check",
    "format": "prettier --write .",
    "clean": "turbo clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/node": "^22.13.4",
    "@typescript-eslint/parser": "^8.24.0",
    "eslint": "^9.20.1",
    "prettier": "^3.5.3",
    "turbo": "^2.4.4",
    "typescript": "^5.7.3",
    "vitest": "^3.0.6"
  }
}
